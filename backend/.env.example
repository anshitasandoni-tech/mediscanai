# Port configuration (automatically set by Render)
PORT=5000

# AI/ML APIs
GEMINI_API_KEY=your_gemini_api_key_here
OCR_API_KEY=your_tesseract_ocr_api_key_here
OPENFDA_API_KEY=your_open_fda_api_key_here

# Firebase Configuration (Required for Dosage Reminders)
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Paste your entire serviceAccountKey.json content here as a single-line JSON string
# Example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json_string_here
